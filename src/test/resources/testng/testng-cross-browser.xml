<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross-Browser Suite" parallel="none" verbose="1">

    <listeners>
        <listener class-name="org.example.listeners.ExtentTestListener"/>
    </listeners>

    <test name="Chromium - Core Tests">
        <parameter name="browser" value="chromium"/>
        <classes>
            <class name="org.example.tests.LoginTest"/>
            <class name="org.example.tests.CartTest"/>
            <class name="org.example.tests.CheckoutTest"/>
        </classes>
    </test>

    <test name="Firefox - Core Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="org.example.tests.LoginTest"/>
            <class name="org.example.tests.CartTest"/>
            <class name="org.example.tests.CheckoutTest"/>
        </classes>
    </test>

    <test name="WebKit - Core Tests">
        <parameter name="browser" value="webkit"/>
        <classes>
            <class name="org.example.tests.LoginTest"/>
            <class name="org.example.tests.CartTest"/>
            <class name="org.example.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
