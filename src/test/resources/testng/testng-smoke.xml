<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" parallel="none" verbose="1">

    <listeners>
        <listener class-name="org.example.listeners.ExtentTestListener"/>
    </listeners>

    <test name="Smoke Tests">
        <classes>
            <class name="org.example.tests.LoginTest">
                <methods>
                    <include name="testValidLoginStandardUser"/>
                </methods>
            </class>
            <class name="org.example.tests.ProductTest">
                <methods>
                    <include name="testProductCountIs6"/>
                    <include name="testAddProductToCart"/>
                </methods>
            </class>
            <class name="org.example.tests.CartTest">
                <methods>
                    <include name="testAddedProductInCart"/>
                </methods>
            </class>
            <class name="org.example.tests.CheckoutTest">
                <methods>
                    <include name="testOrderConfirmation"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
